{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/$1" }
  ],
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "installCommand": "npm install --prefix ./backend && npm install",
  "buildCommand": "npx vite build"
}